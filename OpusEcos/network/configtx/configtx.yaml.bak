Organizations:

  - &OpusOrg
    Name: OpusMSP
    ID: OpusMSP

    MSPDir: ../organizations/peerOrganizations/opusorg.opusecos.net/msp

    Policies:
      Readers:
        Type: Signature
        Rule: "OR('OpusMSP.member')"

      Writers:
        Type: Signature
        Rule: "OR('OpusMSP.member')"

      Admins:
        Type: Signature
        Rule: "OR('OpusMSP.admin')"

      Endorsement:
        Type: Signature
        Rule: "OR('OpusMSP.peer')"
        Capabilities:

  Channel: &ChannelCapabilities
    V2_0: true

  Orderer: &OrdererCapabilities
    V2_0: true

  Application: &ApplicationCapabilities
    V2_5: true
    Application: &ApplicationDefaults

  Organizations:

  Policies:

    Readers:
      Type: ImplicitMeta
      Rule: "ANY Readers"

    Writers:
      Type: ImplicitMeta
      Rule: "ANY Writers"

    Admins:
      Type: ImplicitMeta
      Rule: "MAJORITY Admins"

    LifecycleEndorsement:
      Type: ImplicitMeta
      Rule: "MAJORITY Endorsement"

    Endorsement:
      Type: ImplicitMeta
      Rule: "MAJORITY Endorsement"

  Capabilities:
    <<: *ApplicationCapabilities
    Orderer: &OrdererDefaults

  OrdererType: etcdraft

  Addresses:
    - orderer0.opusecos.net:7050

  BatchTimeout: 2s

  BatchSize:
    MaxMessageCount: 500

    AbsoluteMaxBytes: 99 MB

    PreferredMaxBytes: 2 MB

  Organizations:

  Policies:

    Readers:
      Type: ImplicitMeta
      Rule: "ANY Readers"

    Writers:
      Type: ImplicitMeta
      Rule: "ANY Writers"

    Admins:
      Type: ImplicitMeta
      Rule: "MAJORITY Admins"

    BlockValidation:
      Type: ImplicitMeta
      Rule: "ANY Writers"

  Capabilities:
    <<: *OrdererCapabilities